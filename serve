#!/usr/bin/env bash
# Starts the project report server.
# Generates issues-data.js from bd, then serves docs/ on localhost:8000.
# Open: http://localhost:8000/reports/report.html

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
DATA_FILE="$SCRIPT_DIR/docs/reports/issues-data.js"
PORT="${1:-8000}"

echo "Generating issues data…"
JSON=$(cd "$SCRIPT_DIR" && bd list --json 2>/dev/null | jq 'map(del(.owner))' || echo "[]")
TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

cat > "$DATA_FILE" <<EOF
// Auto-generated by serve on $TIMESTAMP — do not edit by hand.
window.ISSUES_GENERATED_AT = "$TIMESTAMP";
window.ISSUES_DATA = $JSON;
EOF

URL="http://localhost:$PORT/reports/report.html"
echo "Serving docs/ on $URL"
echo "Press Ctrl-C to stop."
echo ""

if command -v open &>/dev/null; then
  (sleep 0.4 && open "$URL") &
elif command -v xdg-open &>/dev/null; then
  (sleep 0.4 && xdg-open "$URL") &
fi

exec python3 -m http.server "$PORT" --directory "$SCRIPT_DIR/docs"
