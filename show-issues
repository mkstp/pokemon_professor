#!/usr/bin/env bash
# Generates docs/reports/issues-data.js from bd and opens the issues viewer.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
DATA_FILE="$SCRIPT_DIR/docs/reports/issues-data.js"

echo "Fetching issues…"
JSON=$(cd "$SCRIPT_DIR" && bd list --json 2>/dev/null)

if [[ -z "$JSON" || "$JSON" == "[]" ]]; then
  echo "No issues returned from bd. Is this a beads project?"
  exit 1
fi

TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

cat > "$DATA_FILE" <<EOF
// Auto-generated by show-issues on $TIMESTAMP — do not edit by hand.
window.ISSUES_GENERATED_AT = "$TIMESTAMP";
window.ISSUES_DATA = $JSON;
EOF

echo "Written to $DATA_FILE"

# Open in default browser
if command -v open &>/dev/null; then
  open "$SCRIPT_DIR/docs/reports/issues.html"
elif command -v xdg-open &>/dev/null; then
  xdg-open "$SCRIPT_DIR/docs/reports/issues.html"
else
  echo "Open manually: $SCRIPT_DIR/docs/reports/issues.html"
fi
